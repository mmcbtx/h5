            <div class="modal-text">
                感谢你为班级投出宝贵一票<br>
                记得转发班级群拉票哦<br>
                明天还可以再来投票
            </div>
            <button class="modal-btn" onclick="closeVoteModal()">好的</button>
        </div>
    </div>

    <script>
        // 滑动翻页逻辑
        let currentPage = 0;
        const totalPages = 5;
        const pagesWrapper = document.getElementById('pagesWrapper');
        const indicators = document.querySelectorAll('.indicator');
        
        let startY = 0;
        let currentY = 0;
        let isMoving = false;

        function updatePage() {
            pagesWrapper.style.transform = `translateY(-${currentPage * 20}%)`;
            indicators.forEach((ind, index) => {
                ind.classList.toggle('active', index === currentPage);
            });
        }

        function goToPage(pageIndex) {
            if (pageIndex < 0 || pageIndex >= totalPages || isMoving) return;
            isMoving = true;
            currentPage = pageIndex;
            updatePage();
            setTimeout(() => {
                isMoving = false;
            }, 800);
        }

        // 触摸事件
        document.addEventListener('touchstart', (e) => {
            if (isMoving) return;
            startY = e.touches[0].clientY;
            currentY = startY;
        });

        document.addEventListener('touchmove', (e) => {
            if (isMoving) return;
            currentY = e.touches[0].clientY;
        });

        document.addEventListener('touchend', (e) => {
            if (isMoving) return;
            const diff = startY - currentY;
            const threshold = 50;

            if (Math.abs(diff) > threshold) {
                if (diff > 0 && currentPage < totalPages - 1) {
                    goToPage(currentPage + 1);
                } else if (diff < 0 && currentPage > 0) {
                    goToPage(currentPage - 1);
                }
            }
        });

        // 鼠标滚轮支持
        let wheelTimer = null;
        document.addEventListener('wheel', (e) => {
            if (isMoving) return;
            clearTimeout(wheelTimer);
            wheelTimer = setTimeout(() => {
                if (e.deltaY > 0 && currentPage < totalPages - 1) {
                    goToPage(currentPage + 1);
                } else if (e.deltaY < 0 && currentPage > 0) {
                    goToPage(currentPage - 1);
                }
            }, 80);
        });

        // 弹窗控制
        function showShareModal() {
            document.getElementById('shareModal').classList.add('show');
        }

        function closeShareModal() {
            document.getElementById('shareModal').classList.remove('show');
        }

        function closeSuccessModal() {
            document.getElementById('successModal').classList.remove('show');
        }

        function closeVoteModal() {
            document.getElementById('voteModal').classList.remove('show');
        }

        // 表单提交
        function submitForm() {
            const className = document.getElementById('className').value;
            const message = document.getElementById('message').value;
            
            if (!className || !message) {
                alert('请填写完整的班级和加油留言哦~');
                return;
            }
            
            document.getElementById('successModal').classList.add('show');
        }

        // 投票逻辑
        let selectedVote = -1;
        
        function selectVote(el, index) {
            document.querySelectorAll('.vote-item').forEach(item => {
                item.classList.remove('selected');
            });
            el.classList.add('selected');
            selectedVote = index;
        }

        function submitVote() {
            if (selectedVote === -1) {
                alert('请先选择你要投票的班级哦~');
                return;
            }
            document.getElementById('voteModal').classList.add('show');
        }

        // 点击弹窗背景关闭
        document.querySelectorAll('.modal').forEach(modal => {
            modal.addEventListener('click', (e) => {
                if (e.target === modal) {
                    modal.classList.remove('show');
                }
            });
        });

        // 生成漂浮粒子
        function createParticles() {
            const pages = document.querySelectorAll('.page');
            pages.forEach(page => {
                for (let i = 0; i < 8; i++) {
                    const particle = document.createElement('div');
                    particle.className = 'particle';
                    particle.style.left = Math.random() * 100 + '%';
                    particle.style.bottom = '-20px';
                    particle.style.animationDelay = Math.random() * 6 + 's';
                    particle.style.animationDuration = (4 + Math.random() * 4) + 's';
                    particle.style.width = (4 + Math.random() * 4) + 'px';
                    particle.style.height = particle.style.width;
                    page.appendChild(particle);
                }
            });
        }

        // 初始化
        updatePage();
        createParticles();
    </script>
</body>
</html>
