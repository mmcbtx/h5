<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>2026校园春季运动会 · 线上应援活动</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        html, body {
            width: 100%;
            height: 100%;
            overflow: hidden;
            font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
        }

        .h5-container {
            width: 100%;
            height: 100%;
            position: relative;
            overflow: hidden;
        }

        .pages-wrapper {
            width: 100%;
            height: 500%;
            position: absolute;
            top: 0;
            left: 0;
            transition: transform 0.8s cubic-bezier(0.645, 0.045, 0.355, 1);
        }

        .page {
            width: 100%;
            height: 20%;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        /* 背景渐变 */
        .bg-main {
            background: 
                radial-gradient(ellipse at 20% 20%, rgba(255,107,107,0.4) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 80%, rgba(0,102,204,0.5) 0%, transparent 50%),
                linear-gradient(180deg, #ff4757 0%, #c23616 30%, #273c75 70%, #192a56 100%);
        }

        .bg-blue {
            background:
                radial-gradient(ellipse at 30% 10%, rgba(100,181,246,0.3) 0%, transparent 40%),
                radial-gradient(ellipse at 70% 90%, rgba(0,102,204,0.4) 0%, transparent 50%),
                linear-gradient(180deg, #1565C0 0%, #0D47A1 50%, #0a3d62 100%);
        }

        .bg-redblue {
            background:
                radial-gradient(circle at 10% 30%, rgba(255,82,82,0.4) 0%, transparent 40%),
                radial-gradient(circle at 90% 70%, rgba(0,150,255,0.4) 0%, transparent 40%),
                linear-gradient(135deg, #e74c3c 0%, #2980b9 100%);
        }

        /* 光斑装饰 */
        .light-spot {
            position: absolute;
            border-radius: 50%;
            filter: blur(60px);
            opacity: 0.5;
            pointer-events: none;
            animation: pulse 4s ease-in-out infinite;
        }

        .light-1 {
            width: 200px;
            height: 200px;
            background: #ff6b6b;
            top: -50px;
            left: -50px;
        }

        .light-2 {
            width: 250px;
            height: 250px;
            background: #4facfe;
            bottom: -80px;
            right: -80px;
            animation-delay: 2s;
        }

        .light-3 {
            width: 180px;
            height: 180px;
            background: #ffd93d;
            top: 40%;
            right: -60px;
            animation-delay: 1s;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); opacity: 0.4; }
            50% { transform: scale(1.2); opacity: 0.6; }
        }

        /* 跑道透视效果 */
        .track-perspective {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 45%;
            perspective: 400px;
            overflow: hidden;
        }

        .track-lines {
            position: absolute;
            bottom: 0;
            left: -20%;
            width: 140%;
            height: 100%;
            background: 
                repeating-linear-gradient(
                    90deg,
                    transparent,
                    transparent 55px,
                    rgba(255,255,255,0.15) 55px,
                    rgba(255,255,255,0.15) 58px
                );
            transform: rotateX(65deg);
            transform-origin: bottom center;
        }

        /* 漂浮粒子 */
        .particle {
            position: absolute;
            width: 6px;
            height: 6px;
            background: rgba(255,255,255,0.6);
            border-radius: 50%;
            pointer-events: none;
            animation: float-up 6s ease-in-out infinite;
        }

        @keyframes float-up {
            0%, 100% { transform: translateY(0) rotate(0deg); opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { transform: translateY(-200px) rotate(180deg); opacity: 0; }
        }

        /* 第1页：首页封面 */
        .hero-badge {
            background: linear-gradient(135deg, rgba(255,230,128,0.9), rgba(255,200,50,0.9));
            color: #8B4513;
            padding: 6px 18px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 20px;
            z-index: 10;
            box-shadow: 0 4px 15px rgba(255,200,50,0.4);
            animation: slideDown 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            letter-spacing: 1px;
        }

        .page1-title {
            font-size: 48px;
            font-weight: 900;
            color: #fff;
            text-align: center;
            line-height: 1.2;
            z-index: 10;
            text-shadow: 
                0 2px 10px rgba(0,0,0,0.3),
                0 0 40px rgba(255,107,107,0.5);
            margin-bottom: 12px;
            animation: slideUp 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55) 0.1s both;
        }

        .page1-title span {
            background: linear-gradient(135deg, #FFE680, #FFD700);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .page1-subtitle {
            font-size: 18px;
            color: rgba(255,255,255,0.9);
            font-weight: 500;
            margin-bottom: 36px;
            z-index: 10;
            letter-spacing: 2px;
            animation: slideUp 0.8s ease 0.2s both;
        }

        .benefit-card {
            background: linear-gradient(135deg, rgba(255,255,255,0.95), rgba(255,255,255,0.85));
            backdrop-filter: blur(20px);
            border-radius: 24px;
            padding: 28px 24px;
            width: 86%;
            max-width: 370px;
            z-index: 10;
            box-shadow: 
                0 20px 60px rgba(0,0,0,0.3),
                0 0 0 1px rgba(255,255,255,0.3) inset;
            animation: slideUp 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55) 0.3s both;
        }

        .benefit-header {
            display: flex;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 14px;
            border-bottom: 2px dashed #eee;
        }

        .benefit-header-icon {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, #ff6b6b, #ee5a5a);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            margin-right: 12px;
            box-shadow: 0 4px 12px rgba(255,107,107,0.4);
        }

        .benefit-header-text {
            font-size: 18px;
            font-weight: 800;
            background: linear-gradient(135deg, #e74c3c, #2980b9);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .benefit-item {
            display: flex;
            align-items: flex-start;
            margin-bottom: 16px;
            font-size: 15px;
            color: #333;
            font-weight: 500;
            line-height: 1.5;
        }

        .benefit-item:last-child {
            margin-bottom: 0;
        }

        .benefit-num {
            width: 28px;
            height: 28px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            border-radius: 10px;
            color: #fff;
            font-size: 14px;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 14px;
            flex-shrink: 0;
            box-shadow: 0 3px 10px rgba(102,126,234,0.4);
        }

        .info-badge {
            margin-top: 24px;
            background: rgba(255,255,255,0.2);
            backdrop-filter: blur(10px);
            border-radius: 12px;
            padding: 12px 20px;
            font-size: 14px;
            color: #fff;
            z-index: 10;
            border: 1px solid rgba(255,255,255,0.2);
            animation: slideUp 0.8s ease 0.5s both;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* 转发应援按钮 - 移到右上角 */
        .share-btn {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 200;
            padding: 10px 18px;
            background: linear-gradient(135deg, #ff6b6b, #ee5a5a);
            border-radius: 25px;
            display: flex;
            align-items: center;
            gap: 6px;
            color: #fff;
            font-size: 13px;
            font-weight: 700;
            box-shadow: 
                0 6px 20px rgba(255,107,107,0.5),
                0 0 0 3px rgba(255,255,255,0.2);
            cursor: pointer;
            animation: float-btn 2.5s ease-in-out infinite;
        }

        .share-icon {
            font-size: 16px;
        }

        @keyframes float-btn {
            0%, 100% { transform: translateY(0); box-shadow: 0 6px 20px rgba(255,107,107,0.5); }
            50% { transform: translateY(-5px); box-shadow: 0 10px 28px rgba(255,107,107,0.6); }
        }

        .scroll-hint {
            position: absolute;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            flex-direction: column;
            align-items: center;
            z-index: 10;
            animation: fadeIn 1s ease 0.8s both;
        }

        .scroll-hint-text {
            font-size: 12px;
            color: rgba(255,255,255,0.7);
            margin-bottom: 8px;
            letter-spacing: 1px;
        }

        .scroll-arrow {
            width: 24px;
            height: 24px;
            border-right: 2px solid rgba(255,255,255,0.7);
            border-bottom: 2px solid rgba(255,255,255,0.7);
            transform: rotate(45deg);
            animation: scroll-bounce 1.5s infinite;
        }

        @keyframes scroll-bounce {
            0%, 100% { transform: rotate(45deg) translate(0, 0); opacity: 0.6; }
            50% { transform: rotate(45deg) translate(6px, 6px); opacity: 1; }
        }

        /* 动画 */
        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(40px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        /* 第2页及以后：回到首页按钮 */
        .back-home-btn {
            position: absolute;
            top: 20px;
            left: 20px;
            z-index: 150;
            padding: 8px 16px;
            background: rgba(255,255,255,0.2);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.3);
            border-radius: 20px;
            color: #fff;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 4px;
            transition: all 0.3s;
        }

        .back-home-btn:active {
            transform: scale(0.95);
            background: rgba(255,255,255,0.3);
        }

        /* 第2页：活动详情 */
        .page-header {
            text-align: center;
            margin-bottom: 28px;
            z-index: 10;
        }

        .page-title {
            font-size: 32px;
            font-weight: 800;
            color: #fff;
            margin-bottom: 8px;
            text-shadow: 0 2px 10px rgba(0,0,0,0.2);
        }

        .page-subtitle {
            font-size: 14px;
            color: rgba(255,255,255,0.8);
            letter-spacing: 1px;
        }

        .detail-card {
            background: linear-gradient(135deg, rgba(255,255,255,0.95), rgba(255,255,255,0.88));
            backdrop-filter: blur(20px);
            border-radius: 20px;
            padding: 22px 20px;
            width: 86%;
            max-width: 370px;
            margin-bottom: 14px;
            z-index: 10;
            box-shadow: 
                0 12px 40px rgba(0,0,0,0.2),
                0 0 0 1px rgba(255,255,255,0.3) inset;
            transition: transform 0.3s;
        }

        .detail-card:active {
            transform: scale(0.98);
        }

        .card-header {
            display: flex;
            align-items: center;
            margin-bottom: 14px;
        }

        .card-icon {
            width: 42px;
            height: 42px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            margin-right: 12px;
            flex-shrink: 0;
        }

        .icon-red {
            background: linear-gradient(135deg, #ff6b6b, #ee5a5a);
            box-shadow: 0 4px 12px rgba(255,107,107,0.4);
        }

        .icon-blue {
            background: linear-gradient(135deg, #4facfe, #00f2fe);
            box-shadow: 0 4px 12px rgba(79,172,254,0.4);
        }

        .icon-purple {
            background: linear-gradient(135deg, #a18cd1, #fbc2eb);
            box-shadow: 0 4px 12px rgba(161,140,209,0.4);
        }

        .card-title {
            font-size: 18px;
            font-weight: 700;
            color: #2d3436;
        }

        .card-content {
            font-size: 14px;
            color: #636e72;
            line-height: 1.7;
        }

        .tag-list {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 4px;
        }

        .tag {
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .tag-red {
            background: rgba(255,107,107,0.15);
            color: #e74c3c;
        }

        .tag-blue {
            background: rgba(79,172,254,0.15);
            color: #2980b9;
        }

        .tag-green {
            background: rgba(46,213,115,0.15);
            color: #27ae60;
        }

        .page-footer {
            font-size: 12px;
            color: rgba(255,255,255,0.6);
            margin-top: 8px;
            z-index: 10;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        /* 第3页：留言打卡 */
        .form-card {
            background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(255,255,255,0.92));
            backdrop-filter: blur(20px);
            border-radius: 28px;
            padding: 32px 26px;
            width: 86%;
            max-width: 370px;
            z-index: 10;
            box-shadow: 
                0 25px 80px rgba(0,0,0,0.3),
                0 0 0 1px rgba(255,255,255,0.4) inset;
        }

        .form-header {
            text-align: center;
            margin-bottom: 26px;
        }

        .form-header-icon {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
            margin: 0 auto 14px;
            box-shadow: 0 8px 25px rgba(102,126,234,0.5);
        }

        .form-header-title {
            font-size: 22px;
            font-weight: 800;
            color: #2d3436;
            margin-bottom: 6px;
        }

        .form-header-desc {
            font-size: 13px;
            color: #b2bec3;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            font-size: 14px;
            font-weight: 600;
            color: #2d3436;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .form-label::before {
            content: '';
            width: 4px;
            height: 14px;
            background: linear-gradient(180deg, #667eea, #764ba2);
            border-radius: 2px;
        }

        .form-input {
            width: 100%;
            padding: 14px 16px;
            border: 2px solid #f0f0f0;
            border-radius: 14px;
            font-size: 15px;
            outline: none;
            transition: all 0.3s;
            font-family: inherit;
            background: #fafafa;
        }

        .form-input:focus {
            border-color: #667eea;
            background: #fff;
            box-shadow: 0 0 0 4px rgba(102,126,234,0.1);
        }

        .form-textarea {
            width: 100%;
            padding: 14px 16px;
            border: 2px solid #f0f0f0;
            border-radius: 14px;
            font-size: 15px;
            outline: none;
            resize: none;
            height: 90px;
            transition: all 0.3s;
            font-family: inherit;
            background: #fafafa;
        }

        .form-textarea:focus {
            border-color: #667eea;
            background: #fff;
            box-shadow: 0 0 0 4px rgba(102,126,234,0.1);
        }

        .submit-btn {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            border-radius: 14px;
            color: #fff;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            box-shadow: 0 8px 25px rgba(102,126,234,0.5);
            transition: all 0.3s;
            letter-spacing: 1px;
        }

        .submit-btn:active {
            transform: scale(0.97);
            box-shadow: 0 4px 15px rgba(102,126,234,0.4);
        }

        .form-tip {
            font-size: 12px;
            color: #b2bec3;
            text-align: center;
            margin-top: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 4px;
        }

        .compliance-text {
            position: absolute;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 11px;
            color: rgba(255,255,255,0.5);
            text-align: center;
            width: 85%;
            z-index: 10;
            line-height: 1.5;
        }

        /* 第4页：投票页 */
        .vote-card {
            background: rgba(255,255,255,0.95);
            backdrop-filter: blur(20px);
            border-radius: 20px;
            padding: 20px;
            width: 86%;
            max-width: 370px;
            max-height: 52%;
            overflow-y: auto;
            z-index: 10;
            box-shadow: 
                0 20px 60px rgba(0,0,0,0.25),
                0 0 0 1px rgba(255,255,255,0.3) inset;
        }

        .vote-item {
            background: #fafafa;
            border-radius: 16px;
            padding: 14px 16px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            border: 2px solid transparent;
        }

        .vote-item:last-child {
            margin-bottom: 0;
        }

        .vote-item:active {
            transform: scale(0.97);
        }

        .vote-item.selected {
            border-color: #667eea;
            background: linear-gradient(135deg, rgba(102,126,234,0.08), rgba(118,75,162,0.08));
            box-shadow: 0 4px 15px rgba(102,126,234,0.2);
        }

        .vote-class-avatar {
            width: 52px;
            height: 52px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 13px;
            font-weight: 700;
            margin-right: 14px;
            flex-shrink: 0;
            text-align: center;
            line-height: 1.2;
        }

        .avatar-1 { background: linear-gradient(135deg, #ff6b6b, #ee5a5a); }
        .avatar-2 { background: linear-gradient(135deg, #4facfe, #00f2fe); }
        .avatar-3 { background: linear-gradient(135deg, #43e97b, #38f9d7); }
        .avatar-4 { background: linear-gradient(135deg, #fa709a, #fee140); }
        .avatar-5 { background: linear-gradient(135deg, #a18cd1, #fbc2eb); }

        .vote-info {
            flex: 1;
            min-width: 0;
        }

        .vote-class-name {
            font-size: 15px;
            font-weight: 600;
            color: #2d3436;
            margin-bottom: 8px;
        }

        .vote-bar-wrap {
            height: 8px;
            background: #eee;
            border-radius: 4px;
            overflow: hidden;
        }

        .vote-bar {
            height: 100%;
            background: linear-gradient(90deg, #667eea, #764ba2);
            border-radius: 4px;
            transition: width 0.6s cubic-bezier(0.645, 0.045, 0.355, 1);
            position: relative;
        }

        .vote-bar::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
            animation: shimmer 2s infinite;
        }

        @keyframes shimmer {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(100%); }
        }

        .vote-count {
            font-size: 13px;
            color: #667eea;
            font-weight: 700;
            margin-left: 12px;
            flex-shrink: 0;
            min-width: 45px;
            text-align: right;
        }

        .vote-action-btn {
            width: 86%;
            max-width: 370px;
            padding: 16px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            border-radius: 14px;
            color: #fff;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            margin-top: 18px;
            z-index: 10;
            box-shadow: 0 8px 25px rgba(102,126,234,0.5);
            transition: all 0.3s;
            letter-spacing: 1px;
        }

        .vote-action-btn:active {
            transform: scale(0.97);
        }

        .vote-footer {
            font-size: 12px;
            color: rgba(255,255,255,0.7);
            margin-top: 12px;
            z-index: 10;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        /* 第5页：福利收尾 */
        .gift-card {
            background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(255,255,255,0.9));
            backdrop-filter: blur(20px);
            border-radius: 28px;
            padding: 28px 24px;
            width: 86%;
            max-width: 370px;
            z-index: 10;
            margin-bottom: 16px;
            box-shadow: 
                0 25px 80px rgba(0,0,0,0.3),
                0 0 0 1px rgba(255,255,255,0.4) inset;
        }

        .gift-header {
            text-align: center;
            margin-bottom: 22px;
        }

        .gift-title {
            font-size: 22px;
            font-weight: 800;
            background: linear-gradient(135deg, #e74c3c, #f39c12);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 6px;
        }

